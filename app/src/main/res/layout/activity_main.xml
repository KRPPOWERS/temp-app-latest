<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0a06"
    android:fitsSystemWindows="false">

    <!-- WebView - full screen -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0d0a06"
        android:visibility="invisible"
        android:overScrollMode="never" />

    <!-- Loading progress bar at top -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_alignParentTop="true"
        android:progressTint="#c9922a"
        android:progressBackgroundTint="#3a2e1a"
        android:indeterminate="false"
        android:max="100"
        android:visibility="gone" />

    <!-- Splash screen shown while WebView loads -->
    <LinearLayout
        android:id="@+id/splashView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#0d0a06">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ॐ"
            android:textSize="72sp"
            android:textColor="#c9922a"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Arulmigu Kallichi"
            android:textSize="18sp"
            android:textColor="#e8b84b"
            android:gravity="center"
            android:letterSpacing="0.06"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Amman Temple"
            android:textSize="18sp"
            android:textColor="#e8b84b"
            android:gravity="center"
            android:letterSpacing="0.06"
            android:fontFamily="serif"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Management System"
            android:textSize="13sp"
            android:textColor="#9a8660"
            android:gravity="center"
            android:layout_marginBottom="40dp" />

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminate="true"
            android:indeterminateTint="#c9922a" />

    </LinearLayout>

</RelativeLayout>
